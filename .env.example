# ==================================================
# Alrhomi Catalog - Unified Environment Template
# Copy to .env and fill with real values
# ==================================================

# --- Core ---
PROJECT_SLUG=alrhomi-catalog
NODE_ENV=production
APP_PORT=5000

# --- Domains ---
DOMAIN=catalog.example.com
API_DOMAIN=api.catalog.example.com
ALLOWED_ORIGINS=https://catalog.example.com,https://admin.catalog.example.com
FRONTEND_URL=https://catalog.example.com

# --- Database (Preferred: single URI) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/product-catalog

# --- Database (Optional fallback parts, use only if MONGODB_URI is not provided) ---
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=product-catalog

# --- Redis / Queue ---
REDIS_URL=redis://redis:6379

# --- Auth ---
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Frontend runtime/build ---
REACT_APP_API_BASE_URL=https://api.catalog.example.com
REACT_APP_WHATSAPP_NUMBER=967700000000

# --- Object Storage (S3) ---
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=catalog-assets

# --- Ops / SSL ---
CERTBOT_EMAIL=ops@example.com
